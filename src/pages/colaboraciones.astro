---
import Layout from '../layouts/Layout.astro';

const eventos = [
  {
    anio: 2024,
    items: [
      {
        tipo: 'Festival',
        nombre: 'Festival Internacional de Poesía de Montreal',
        rol: 'Participante — lectura de poesía',
        lugar: 'Montreal, QC',
      },
      {
        tipo: 'Salón del libro',
        nombre: 'Salon du livre de Québec',
        rol: 'Mesa redonda: La poesía en la diáspora',
        lugar: 'Quebec, QC',
      },
    ],
  },
  {
    anio: 2023,
    items: [
      {
        tipo: 'Mediación cultural',
        nombre: 'Taller de escritura creativa',
        rol: 'Coordinación y facilitación',
        lugar: 'Quebec, QC',
      },
    ],
  },
];
---

<Layout title="Colaboraciones y eventos" description="Participaciones en festivales, salones del libro y mediación cultural de Ana Luna.">

  <h1 class="section-title">Colaboraciones y eventos</h1>
  <hr class="section-divider" />

  <p class="page-intro">
    Participaciones en festivales internacionales, salones del libro, mesas redondas
    y proyectos de mediación cultural.
  </p>

  <div class="eventos-lista">
    {eventos.map((grupo) => (
      <div class="anio-grupo">
        <h2 class="anio-titulo">{grupo.anio}</h2>
        <ul class="eventos-items">
          {grupo.items.map((ev) => (
            <li class="evento-item">
              <span class="evento-tipo">{ev.tipo}</span>
              <h3 class="evento-nombre">{ev.nombre}</h3>
              <p class="evento-rol">{ev.rol}</p>
              <p class="evento-lugar">{ev.lugar}</p>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <!-- Comunidades literarias -->
  <section class="extra-seccion">
    <h2 class="extra-titulo">Comunidades literarias</h2>
    <ul class="extra-lista">
      <li class="extra-item">
        <h3 class="extra-nombre">Club de escritura Fuentetaja</h3>
        <p class="extra-desc">Un club de escritura abierto a todos con concursos y lecturas. Puedes leer algunos de mis cuentos y participar.</p>
        <a href="https://clubdeescritura.com/perfil/178035/ana-luna-2/#folder-220821" target="_blank" rel="noopener" class="extra-enlace">Ver perfil ↗</a>
      </li>
      <li class="extra-item">
        <h3 class="extra-nombre">Proyecto Sherezade — Universidad de Manitoba</h3>
        <p class="extra-desc">Un proyecto donde puedes leer cuentos de todo el mundo de habla hispana y enviar tus propias colaboraciones. He tenido el honor de colaborar con ellos.</p>
        <a href="https://home.cc.umanitoba.ca/~fernand4/index.html" target="_blank" rel="noopener" class="extra-enlace">Visitar proyecto ↗</a>
      </li>
    </ul>
  </section>

  <!-- Ferias del libro -->
  <section class="extra-seccion">
    <h2 class="extra-titulo">Ferias del libro</h2>
    <ul class="extra-lista">
      <li class="extra-item">
        <h3 class="extra-nombre">Feria del libro Ser y estar en español — Quebec</h3>
        <p class="extra-desc">Feria que celebra la lengua española en Quebec. Participé en la edición de abril.</p>
        <a href="https://www.seryestar.ca/événements" target="_blank" rel="noopener" class="extra-enlace">Ver eventos ↗</a>
      </li>
      <li class="extra-item">
        <h3 class="extra-nombre">Feria Internacional del Libro de La Habana</h3>
        <p class="extra-desc">La feria que llevo siempre en el corazón. El Encuentro de Jóvenes Escritores de Iberoamérica es uno de sus eventos más especiales.</p>
      </li>
    </ul>
  </section>

</Layout>

<style>
  .extra-seccion {
    margin-top: 3.5rem;
    padding-top: 2.5rem;
    border-top: 1px solid rgba(61,43,107,0.12);
  }
  .extra-titulo {
    font-size: 1.4rem;
    color: var(--color-accent);
    border-bottom: 2px solid var(--color-accent);
    padding-bottom: 0.4rem;
    margin-bottom: 1.5rem;
    display: inline-block;
  }
  .extra-lista {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .extra-item {
    border-left: 3px solid var(--color-secondary);
    padding-left: 1.25rem;
  }
  .extra-nombre {
    font-size: 1.15rem;
    margin: 0 0 0.3rem;
  }
  .extra-desc {
    font-size: 0.95rem;
    color: var(--color-text);
    margin: 0 0 0.5rem;
    line-height: 1.65;
  }
  .extra-enlace {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--color-secondary);
  }
  .extra-enlace:hover { color: var(--color-accent); }
  .page-intro {
    max-width: 620px;
    margin: 0 auto 3rem;
    text-align: center;
    color: var(--color-muted);
    font-size: 1rem;
  }
  .anio-grupo {
    margin-bottom: 3rem;
  }
  .anio-titulo {
    font-size: 1.4rem;
    color: var(--color-accent);
    border-bottom: 2px solid var(--color-accent);
    padding-bottom: 0.4rem;
    margin-bottom: 1.5rem;
    display: inline-block;
  }
  .eventos-items {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .evento-item {
    border-left: 3px solid var(--color-secondary);
    padding-left: 1.25rem;
  }
  .evento-tipo {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-secondary);
    margin-bottom: 0.2rem;
  }
  .evento-nombre {
    font-size: 1.15rem;
    margin: 0.1rem 0 0.2rem;
  }
  .evento-rol {
    font-size: 0.95rem;
    margin: 0 0 0.1rem;
    color: var(--color-text);
  }
  .evento-lugar {
    font-size: 0.85rem;
    color: var(--color-muted);
    margin: 0;
  }
</style>
