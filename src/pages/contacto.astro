---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contacto" description="Escríbele a Ana Luna — colaboraciones, prensa, eventos.">

  <h1 class="section-title">Contacto</h1>
  <hr class="section-divider" />

  <div class="contacto-wrap">
    <p class="contacto-intro">
      ¿Tienes una propuesta de colaboración, pregunta de prensa o simplemente quieres escribir?
      Usa el formulario y te respondo a la brevedad.
    </p>

    <form
      name="contacto"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      class="contacto-form"
    >
      <input type="hidden" name="form-name" value="contacto" />
      <p class="hidden"><label>No rellenar: <input name="bot-field" /></label></p>

      <div class="form-row">
        <label for="nombre">Nombre</label>
        <input type="text" id="nombre" name="nombre" required placeholder="Tu nombre" />
      </div>

      <div class="form-row">
        <label for="email">Correo electrónico</label>
        <input type="email" id="email" name="email" required placeholder="tu@correo.com" />
      </div>

      <div class="form-row">
        <label for="asunto">Asunto</label>
        <input type="text" id="asunto" name="asunto" placeholder="Colaboración, prensa, otro…" />
      </div>

      <div class="form-row">
        <label for="mensaje">Mensaje</label>
        <textarea id="mensaje" name="mensaje" rows="6" required placeholder="Tu mensaje…"></textarea>
      </div>

      <button type="submit" class="btn btn-primary">Enviar mensaje</button>
    </form>
  </div>

</Layout>

<style>
  .contacto-wrap {
    max-width: 580px;
    margin: 0 auto;
  }
  .contacto-intro {
    text-align: center;
    color: var(--color-muted);
    margin-bottom: 2.5rem;
  }
  .hidden { display: none; }
  .contacto-form {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
  }
  .form-row {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  label {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: 0.02em;
  }
  input, textarea {
    font-family: var(--font-body);
    font-size: 1rem;
    padding: 0.65rem 0.9rem;
    border: 1.5px solid rgba(61,43,107,0.25);
    border-radius: 4px;
    background: #fff;
    color: var(--color-text);
    transition: border-color 0.2s;
    resize: vertical;
  }
  input:focus, textarea:focus {
    outline: none;
    border-color: var(--color-secondary);
  }
  button[type="submit"] {
    align-self: flex-start;
    margin-top: 0.5rem;
  }
</style>
