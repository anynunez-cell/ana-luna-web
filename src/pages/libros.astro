---
import Layout from '../layouts/Layout.astro';

const libros = [
  {
    titulo: 'Crónicas domésticas',
    anio: null,
    editorial: null,
    descripcion: 'Con prólogo de Reyna Esperanza Cruz.',
    cita: '«Una joya de la narrativa breve que convierte lo cotidiano en una fuente inagotable de revelaciones.»',
    citaFuente: 'Hablemos Escritoras, noviembre 2025',
    portada: '/images/libros/cronicas-domesticas.jpg',
    compra: 'https://www.amazon.ca/-/fr/Cr%C3%B3nicas-dom%C3%A9sticas-Ana-Nunez-Gonzalez/dp/B09S5ZNBM8/',
    compraLabel: 'Comprar en Amazon ↗',
  },
  {
    titulo: 'Mujeres rotas',
    anio: null,
    editorial: null,
    descripcion: '',
    portada: '/images/libros/mujeres-rotas.jpg',
    compra: 'https://www.amazon.ca/-/fr/Mujeres-rotas-Ana-Luna/dp/292544640X/',
    compraLabel: 'Comprar en Amazon ↗',
  },
  {
    titulo: 'Adela y el poder',
    anio: null,
    editorial: 'Cristálida Ediciones',
    descripcion: '',
    portada: '/images/libros/adela-y-el-poder.jpg',
    compra: 'https://lasamericas.ca/fr/produits/36847/adela-y-el-poder-cristalida',
    compraLabel: 'Comprar en Las Américas Bookstore ↗',
  },
  {
    titulo: 'Adela et le pouvoir',
    anio: null,
    editorial: 'Cristálida Ediciones',
    descripcion: 'Mémoires d\'une procureure à La Havane.',
    portada: '/images/libros/adela-et-le-pouvoir.jpg',
    compra: 'https://www.amazon.ca/-/fr/Ad%C3%A8la-pouvoir-M%C3%A9moires-procureure-Havane/dp/2925321836/',
    compraLabel: 'Comprar en Amazon ↗',
  },
  {
    titulo: 'Chroniques du quotidien',
    anio: null,
    editorial: 'Cristálida Ediciones',
    descripcion: 'Cuba au féminin.',
    portada: '/images/libros/chroniques-du-quotidien.jpg',
    compra: null,
    compraLabel: null,
  },
];
---

<Layout title="Libros" description="Libros publicados por Ana Luna — Ana Núñez González.">

  <h1 class="section-title">Libros</h1>
  <hr class="section-divider" />

  <div class="libros-grid">
    {libros.map((libro) => (
      <article class="libro-card">
        <div class="libro-portada">
          <img src={libro.portada} alt={`Portada de ${libro.titulo}`} />
        </div>
        <div class="libro-info">
          <h2 class="libro-titulo">{libro.titulo}</h2>
          {(libro.editorial || libro.anio) && (
            <p class="libro-meta">
              {[libro.editorial, libro.anio].filter(Boolean).join(' · ')}
            </p>
          )}
          {libro.descripcion && <p class="libro-desc">{libro.descripcion}</p>}
          {libro.cita && (
            <blockquote class="libro-cita">
              <p>{libro.cita}</p>
              {libro.citaFuente && <footer class="libro-cita-fuente">— {libro.citaFuente}</footer>}
            </blockquote>
          )}
          {libro.compra && (
            <a href={libro.compra} target="_blank" rel="noopener" class="btn btn-primary">
              {libro.compraLabel}
            </a>
          )}
        </div>
      </article>
    ))}
  </div>

</Layout>

<style>
  .libros-grid {
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
  }
  .libro-card {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 2.5rem;
    align-items: start;
    padding-bottom: 3.5rem;
    border-bottom: 1px solid rgba(61,43,107,0.12);
  }
  .libro-card:last-child { border-bottom: none; padding-bottom: 0; }
  @media (max-width: 600px) {
    .libro-card {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .libro-portada { margin: 0 auto; }
  }
  .libro-portada img {
    width: 200px;
    height: 280px;
    object-fit: cover;
    border-radius: 4px;
    box-shadow: var(--box-shadow);
  }
  .libro-titulo {
    font-size: 1.8rem;
    margin-bottom: 0.2rem;
  }
  .libro-meta {
    font-size: 0.9rem;
    color: var(--color-muted);
    margin-bottom: 1rem;
  }
  .libro-desc {
    font-size: 1rem;
    line-height: 1.75;
    margin-bottom: 1rem;
  }
  .libro-cita {
    margin: 0 0 1.5rem;
    padding-left: 1rem;
    border-left: 3px solid var(--color-accent);
  }
  .libro-cita p {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-style: italic;
    color: var(--color-text);
    line-height: 1.6;
    margin: 0 0 0.3rem;
  }
  .libro-cita-fuente {
    font-size: 0.82rem;
    color: var(--color-muted);
    font-style: normal;
  }
</style>
