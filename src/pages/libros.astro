---
import Layout from '../layouts/Layout.astro';

const libros = [
  {
    titulo: 'Título del libro 1',
    anio: 2024,
    editorial: 'Cristálida Ediciones',
    descripcion: 'Descripción breve del libro. Añade aquí el texto que quieras mostrar sobre esta obra.',
    portada: '/images/libros/libro-1.jpg',
    amazon: 'https://amazon.com',
  },
  {
    titulo: 'Título del libro 2',
    anio: 2021,
    editorial: 'Editorial X',
    descripcion: 'Descripción breve del libro. Añade aquí el texto que quieras mostrar sobre esta obra.',
    portada: '/images/libros/libro-2.jpg',
    amazon: 'https://amazon.com',
  },
];
---

<Layout title="Libros" description="Libros publicados por Ana Luna — Ana Núñez González.">

  <h1 class="section-title">Libros</h1>
  <hr class="section-divider" />

  <div class="libros-grid">
    {libros.map((libro) => (
      <article class="libro-card">
        <div class="libro-portada">
          <img src={libro.portada} alt={`Portada de ${libro.titulo}`} />
        </div>
        <div class="libro-info">
          <h2 class="libro-titulo">{libro.titulo}</h2>
          <p class="libro-meta">{libro.editorial} · {libro.anio}</p>
          <p class="libro-desc">{libro.descripcion}</p>
          {libro.amazon && (
            <a href={libro.amazon} target="_blank" rel="noopener" class="btn btn-primary">
              Comprar en Amazon ↗
            </a>
          )}
        </div>
      </article>
    ))}
  </div>

</Layout>

<style>
  .libros-grid {
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
  }
  .libro-card {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 2.5rem;
    align-items: start;
    padding-bottom: 3.5rem;
    border-bottom: 1px solid rgba(61,43,107,0.12);
  }
  .libro-card:last-child { border-bottom: none; padding-bottom: 0; }
  @media (max-width: 600px) {
    .libro-card {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .libro-portada { margin: 0 auto; }
  }
  .libro-portada img {
    width: 200px;
    height: 280px;
    object-fit: cover;
    border-radius: 4px;
    box-shadow: var(--box-shadow);
  }
  .libro-titulo {
    font-size: 1.8rem;
    margin-bottom: 0.2rem;
  }
  .libro-meta {
    font-size: 0.9rem;
    color: var(--color-muted);
    margin-bottom: 1rem;
  }
  .libro-desc {
    font-size: 1rem;
    line-height: 1.75;
    margin-bottom: 1.5rem;
  }
</style>
