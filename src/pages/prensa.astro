---
import Layout from '../layouts/Layout.astro';

const medios = [
  {
    medio: 'Hablemos Escritoras',
    descripcion: 'Podcast y enciclopedia de escritoras en español',
    cita: '«Crónicas domésticas es una joya de la narrativa breve que convierte lo cotidiano en una fuente inagotable de revelaciones.»',
    detalles: 'Minireseña publicada en noviembre 2025. También disponible: Episodio 673 del podcast.',
    enlaces: [
      { label: 'Ver reseña', url: 'https://www.hablemosescritoras.org/posts/7351' },
      { label: 'Perfil completo', url: 'https://www.hablemosescritoras.org/writers/4810' },
    ],
  },
  {
    medio: 'FILibro Canadá',
    descripcion: 'Feria Iberoamericana del Libro en Canadá',
    cita: null,
    detalles: 'Cristálida Ediciones ha participado como expositora en FILibro Canadá 2023 y 2024.',
    enlaces: [
      { label: 'Ver página', url: 'https://www.filibrocanada.com/cristalida-ediciones.html' },
    ],
  },
];

const eventos = [
  {
    fechaDisplay: '25–28 de junio de 2026',
    nombre: 'Festival Littéraire des Îles — Portages',
    lugar: 'Îles-de-la-Madeleine, Quebec',
    participacion: [
      'Animadora de la conferencia «Mers jumelles: imaginaires insulaires croisés entre les Îles-de-la-Madeleine et Cuba».',
      'Lectura en el evento de apertura.',
      'Cercle d\'autrices junto a Naomi Fontaine, Juli Delporte y Claire Vigneau.',
      'Lectura infantil de Cuentos para Bárbara de Reyna Esperanza Cruz.',
    ],
    enlace: 'https://www.sitedelacote.ca/portages',
    proximo: true,
  },
  {
    fechaDisplay: '2–4 de octubre de 2026',
    nombre: 'Feria Iberoamericana del Libro en Canadá',
    lugar: 'Ottawa',
    participacion: [
      'Presentación de La flor por nacer (primera antología cubano-canadiense) y Picadillo a la miseria.',
      'Cristálida Ediciones como editorial expositora.',
    ],
    enlace: 'https://www.filibrocanada.com',
    proximo: true,
  },
];
---

<Layout title="Prensa y eventos" description="Menciones en medios y participaciones en eventos de Ana Luna — Ana Núñez González.">

  <!-- EN LOS MEDIOS -->
  <h1 class="section-title">Prensa y eventos</h1>
  <hr class="section-divider" />

  <section class="bloque">
    <h2 class="bloque-titulo">En los medios</h2>
    <div class="medios-grid">
      {medios.map((item) => (
        <article class="medio-card">
          <p class="medio-nombre">{item.medio}</p>
          <p class="medio-desc">{item.descripcion}</p>
          {item.cita && <blockquote class="medio-cita">{item.cita}</blockquote>}
          <p class="medio-detalles">{item.detalles}</p>
          <div class="medio-enlaces">
            {item.enlaces.map((e) => (
              <a href={e.url} target="_blank" rel="noopener" class="btn btn-outline btn-sm">
                {e.label} ↗
              </a>
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- EVENTOS Y PARTICIPACIONES -->
  <section class="bloque">
    <h2 class="bloque-titulo">Eventos y participaciones</h2>
    <div class="eventos-lista">
      {eventos.map((ev) => (
        <article class="evento-card">
          <div class="evento-fecha-col">
            <span class="evento-fecha">{ev.fechaDisplay}</span>
            {ev.proximo && <span class="evento-badge">Próximo</span>}
          </div>
          <div class="evento-info">
            <h3 class="evento-nombre">{ev.nombre}</h3>
            <p class="evento-lugar">{ev.lugar}</p>
            <ul class="evento-participacion">
              {ev.participacion.map((p) => (
                <li>{p}</li>
              ))}
            </ul>
            <a href={ev.enlace} target="_blank" rel="noopener" class="evento-link">
              Ver evento ↗
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>

</Layout>

<style>
  .bloque {
    margin-bottom: 4rem;
  }
  .bloque-titulo {
    font-size: 1.6rem;
    margin-bottom: 0.3rem;
    padding-bottom: 0.4rem;
    border-bottom: 2px solid var(--color-accent);
    display: inline-block;
  }

  /* Medios */
  .medios-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
    margin-top: 1.8rem;
  }
  .medio-card {
    border: 1px solid rgba(61,43,107,0.15);
    border-radius: 8px;
    padding: 1.5rem 1.75rem;
    background: #fff;
    box-shadow: var(--box-shadow);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .medio-nombre {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-primary);
    margin: 0;
  }
  .medio-desc {
    font-size: 0.85rem;
    color: var(--color-muted);
    margin: 0;
    font-style: italic;
  }
  .medio-cita {
    margin: 0.5rem 0;
    padding-left: 1rem;
    border-left: 3px solid var(--color-accent);
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-style: italic;
    color: var(--color-text);
    line-height: 1.6;
  }
  .medio-detalles {
    font-size: 0.9rem;
    color: var(--color-text);
    margin: 0;
  }
  .medio-enlaces {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }
  .btn-sm {
    padding: 0.45rem 1rem;
    font-size: 0.82rem;
  }

  /* Eventos */
  .eventos-lista {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: 1.8rem;
  }
  .evento-card {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 2rem;
    padding: 1.75rem 0;
    border-bottom: 1px solid rgba(61,43,107,0.12);
  }
  .evento-card:last-child { border-bottom: none; }
  @media (max-width: 600px) {
    .evento-card { grid-template-columns: 1fr; gap: 0.75rem; }
    .medios-grid { grid-template-columns: 1fr; }
  }
  .evento-fecha-col {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 0.15rem;
  }
  .evento-fecha {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-secondary);
    line-height: 1.3;
  }
  .evento-badge {
    display: inline-block;
    background: var(--color-accent);
    color: var(--color-primary);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
    align-self: flex-start;
  }
  .evento-nombre {
    font-size: 1.2rem;
    margin: 0 0 0.2rem;
  }
  .evento-lugar {
    font-size: 0.85rem;
    color: var(--color-muted);
    margin: 0 0 0.75rem;
  }
  .evento-participacion {
    margin: 0 0 1rem;
    padding-left: 1.2rem;
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-text);
  }
  .evento-participacion li { margin-bottom: 0.3rem; }
  .evento-link {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-secondary);
  }
  .evento-link:hover { color: var(--color-accent); }
</style>
